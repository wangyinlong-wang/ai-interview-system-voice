# AI 模拟面试系统 - 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 必需配置 ====================

# OpenAI 兼容 API 配置
# 支持: OpenAI / DeepSeek / 通义千问 / 其他兼容 OpenAI 格式的 API
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# JWT 密钥（生产环境请使用随机生成的强密钥）
SECRET_KEY=your-secret-key-change-in-production

# ==================== 可选配置 ====================

# 数据库（默认使用 SQLite）
# DATABASE_URL=sqlite+aiosqlite:///./uploads/interview.db

# 文件上传目录
# UPLOAD_DIR=./uploads/resumes

# 调试模式
# DEBUG=false

# CORS 允许的前端地址（逗号分隔）
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
